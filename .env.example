# ─────────────────────────────────────────────────────────────────────────────
#  middler — environment template
#  Copy to `.env` and fill in. NEVER commit `.env`. All keys below are free to
#  obtain (see README + API_SIGNUP.md). Money-touching keys live at the bottom.
#
#  NOTE: keep comments on their own lines. Docker Compose's env_file reader keeps
#  an inline `# comment` as part of the value, which breaks empty keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Odds data feeds (free tiers) ─────────────────────────────────────────────
# See API_SIGNUP.md for what each gives you and which are free for historical.

# The Odds API — https://the-odds-api.com (free ~500 credits/month). WIRED: primary feed.
THE_ODDS_API_KEY=

# odds-api.io — https://odds-api.io (free: 2 books, 100 req/hour). WIRED: secondary feed.
ODDS_API_IO_KEY=

# OddsPapi — https://oddspapi.io (free 250 req/mo, incl. Pinnacle AND free historical).
# Slot ready; client is a quick follow-on.
ODDSPAPI_KEY=

# SportsGameOdds — https://sportsgameodds.com (free tier + 7-day paid trial). Slot only.
SPORTSGAMEODDS_KEY=

# OpticOdds — https://opticodds.com (free trial on request; premium). Slot only.
OPTICODDS_KEY=

# ── Telegram alerter (free) ──────────────────────────────────────────────────
# Create a bot via @BotFather to get the token, then run `middler-chatid`
# (after messaging the bot once) to discover your chat id.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids; operator first, reviewer second.
TELEGRAM_CHAT_IDS=

# ── Hot store ────────────────────────────────────────────────────────────────
# If unset/unreachable, middler falls back to an in-process store. Under Docker
# Compose this is overridden to the redis service automatically.
REDIS_URL=redis://localhost:6379/0

# ── History store ────────────────────────────────────────────────────────────
DUCKDB_PATH=data/odds.duckdb

# ── Uptime monitor (Phase 7, free) ───────────────────────────────────────────
# healthchecks.io ping URL — the app pings this each cycle so you're alerted if
# the box goes silent. Leave blank to disable.
HEALTHCHECK_PING_URL=

# ─────────────────────────────────────────────────────────────────────────────
#  MONEY-TOUCHING — leave blank until the backcast + forward-test have proved the
#  concept (proposal §5, Phase 6). Placement stays disabled while blank.
# ─────────────────────────────────────────────────────────────────────────────
# Betfair delayed key is free; the live key is the ~A$940 spend.
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
# Path to the client cert .pem for non-interactive login.
BETFAIR_CERT_FILE=
# Path to the client key .pem.
BETFAIR_KEY_FILE=
# Hard master-switch for placement. Keep false until proven.
PLACEMENT_ENABLED=false
