# ─────────────────────────────────────────────────────────────────────────────
#  middler — environment template
#  Copy to `.env` and fill in. NEVER commit `.env`. All keys below are free to
#  obtain (see README "Manual actions"). Money-touching keys live at the bottom.
# ─────────────────────────────────────────────────────────────────────────────

# ── Odds data feeds (free tiers) ─────────────────────────────────────────────
# The Odds API — https://the-odds-api.com (free ~500 credits/month)
THE_ODDS_API_KEY=

# odds-api.io — https://odds-api.io (free forever, 100 req/hour)
ODDS_API_IO_KEY=

# OddsPapi — optional sanity-check feed (free tier, includes Pinnacle)
ODDSPAPI_KEY=

# ── Telegram alerter (free) ──────────────────────────────────────────────────
# Create a bot via @BotFather to get the token, then run `middler-chatid`
# (after messaging the bot once) to discover your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=          # comma-separated; operator first, reviewer second

# ── Hot store ────────────────────────────────────────────────────────────────
# If unset/unreachable, middler falls back to an in-process store (fine for dev
# and single-process runs; Redis is only needed to share state across processes).
REDIS_URL=redis://localhost:6379/0

# ── History store ────────────────────────────────────────────────────────────
DUCKDB_PATH=data/odds.duckdb

# ── Uptime monitor (Phase 7, free) ───────────────────────────────────────────
# healthchecks.io ping URL — the app pings this each cycle; you get an alert if
# the Pi goes silent. Leave blank to disable.
HEALTHCHECK_PING_URL=

# ─────────────────────────────────────────────────────────────────────────────
#  ⚠️  MONEY-TOUCHING — leave blank until the backcast + forward-test have proved
#  the concept (proposal §5, Phase 6). Placement stays disabled while blank.
# ─────────────────────────────────────────────────────────────────────────────
BETFAIR_APP_KEY=           # delayed key is free; live key is the ~A$940 spend
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_FILE=         # path to client cert .pem for non-interactive login
BETFAIR_KEY_FILE=          # path to client key .pem
PLACEMENT_ENABLED=false    # hard master-switch; keep false until proven
